# Hermes WebUI configuration example
# Copy this file to .env and adjust values. Do not commit real secrets.

HERMES_API_BASE=http://127.0.0.1:8642
HERMES_MODEL=hermes-agent
HERMES_API_KEY=replace-with-local-hermes-api-server-key

# Password login is disabled by default.
# Set WEBUI_AUTH_ENABLED=true and WEBUI_PASSWORD_HASH to enable it.
WEBUI_AUTH_ENABLED=false
WEBUI_PASSWORD_HASH=
WEBUI_SESSION_SECRET=replace-with-random-session-secret
